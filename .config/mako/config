# GLOBAL
max-history=100
sort=-time

# BINDING OPTIONS
on-button-left=dismiss
on-button-middle=dismiss
on-button-right=dismiss
on-touch=dismiss
on-notify=exec mpv /home/lzx/.local/share/sounds/message.oga

# STYLE OPTIONS
font="JetBrainsMono Nerd Font", 12
background-color=#000000
text-color=#cccccc
width=300
height=100
outer-margin=0
margin=5
padding=12,20
border-size=1
border-radius=8
border-color=#ffffff0A

icons=1
max-icon-size=64
icon-path="/usr/share/icons/hicolor"
icon-location=left
markup=1
actions=1
history=1
text-alignment=left
default-timeout=3500
ignore-timeout=1
max-visible=5
layer=overlay
anchor=top-right

[summary="Brightness"]
on-notify=none

[summary="Volume"]
on-notify=none
